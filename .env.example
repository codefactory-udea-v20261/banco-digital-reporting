# Banco Digital Reporting Service - Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_PROFILE=local
APP_PORT=8083

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=banco_digital_reporting
DB_USERNAME=
DB_PASSWORD=

# Eureka
EUREKA_URL=http://localhost:8761/eureka/

# JWT
JWT_SECRET=your_base64_encoded_256bit_secret_here
JWT_EXPIRATION_MS=3600000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Vault
VAULT_HOST=localhost
VAULT_PORT=8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# Zipkin
ZIPKIN_URL=http://localhost:9411/api/v2/spans
